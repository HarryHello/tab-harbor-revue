{
  "manifest_version": 3,
  "name": "Tab Harbor reVue",
  "version": "1.0.4",
  "description": "Transform your browser tabs into a calm, organized workspace",
  "permissions": [
    "tabs",
    "storage",
    "search",
    "favicon"
  ],
  "background": {
    "service_worker": "extension/background.ts"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tab Harbor"
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}